---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Image } from 'astro:assets'

import aerolinea from '@assets/img/aerolinea.drawio.png'
import residuos from '@assets/img/Residuos.png'
import comidas from '@assets/img/comidas.png'

import imagen1 from '@assets/img/enunciado1.png'
import imagen2 from '@assets/img/enunciado2.png'
import imagen3 from '@assets/img/enunciado3.png'

import employees from '@assets/img/employe.png'
import transportes from '@assets/img/conductor.png'
---

<DefaultLayout title="Modelado - Einny Camyla">

  <section class="py-20 container max-w-5xl mx-auto">

    <!-- TITULO -->
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold mb-4 text-white">
        Modelado
      </h1>

      <p class="text-zinc-400 text-lg">
        Modelos entidad-relación desarrollados para distintos casos de estudio.
      </p>
    </div>

    <!-- MODELO 1 -->
    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-purple-500 via-pink-500 to-indigo-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-pink-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 1 — Aerolínea
          </h2>
        </div>

        <div class="space-y-5 text-zinc-300 leading-relaxed">

          <p>
            Una aerolínea requiere una base de datos relacional para registrar
            sus operaciones.
          </p>

          <ul class="list-disc pl-6 space-y-3">
            <li>
              La aerolínea tiene tres recursos principales:
              <strong class="text-white"> aviones, pilotos y tripulación.</strong>
            </li>

            <li>
              Los aviones tienen un código (número de cola), un tipo de avión y
              una base a donde pertenece y debe regresar cada número de horas.
            </li>

            <li>
              Los pilotos tienen un código, nombre y horas de vuelo.
            </li>

            <li>
              Los miembros de la tripulación tienen un código, nombre y teléfonos.
            </li>

            <li>
              Pilotos y tripulación tienen una base a la que regresan después
              de cada jornada.
            </li>

            <li>
              Los vuelos van desde un origen a un destino a una hora concreta y
              tienen un número de vuelo.
            </li>
          </ul>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={aerolinea}
            alt="Modelo ER Aerolínea"
            class="w-full object-contain rounded-lg"
          />
        </div>

      </div>
    </div>

    <!-- MODELO 2 -->
    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-cyan-500 via-blue-500 to-indigo-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-cyan-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 2 — Residuos Tóxicos
          </h2>
        </div>

        <div class="space-y-5 text-zinc-300 leading-relaxed">

          <p>
            Gestión ambiental de residuos tóxicos y peligrosos,
            incluyendo productores, residuos, empresas transportadoras
            y traslados.
          </p>

          <ul class="list-disc pl-6 space-y-3">
            <li>Un residuo puede tener varios constituyentes químicos.</li>
            <li>Los residuos pueden transportarse parcial o totalmente.</li>
            <li>En un traslado participan distintas empresas transportistas.</li>
            <li>Los residuos reciben tratamientos especiales.</li>
            <li>Los traslados poseen un único destino.</li>
          </ul>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={residuos}
            alt="Modelo ER Residuos"
            class="w-full object-contain rounded-lg"
          />
        </div>

        <p class="mt-6 text-zinc-300">
          Ingreso al ejercicio:
          <a
            href="https://drive.google.com/file/d/18cFeP9F3HFqef52bL8cAcNfVfMyMgXfb/view?usp=sharing"
            target="_blank"
            class="text-cyan-400 hover:underline"
          >
            Ver archivo
          </a>
        </p>

      </div>
    </div>

    <!-- MODELO 3 -->
    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-emerald-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 3 — Comidas a Domicilio
          </h2>
        </div>

        <div class="space-y-5 text-zinc-300 leading-relaxed">

          <p>
            Eat’n Go es una empresa dedicada a la comercialización
            de comidas rápidas.
          </p>

          <ul class="list-disc pl-6 space-y-3">
            <li>Las pizzas y bocadillos poseen ingredientes variables.</li>
            <li>Los artículos pueden venderse en distintos tamaños.</li>
            <li>Los pedidos pueden ser locales o a domicilio.</li>
            <li>Existen promociones y regalos para clientes.</li>
            <li>La empresa cuenta con repartidores y scooters.</li>
          </ul>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={comidas}
            alt="Modelo ER Comidas"
            class="w-full object-contain rounded-lg"
          />
        </div>

      </div>
    </div>

    <!-- MODELO 4 -->
    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-orange-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 4
          </h2>
        </div>

        <p class="text-zinc-300">
          El enunciado del problema se presenta dividido en tres partes:
        </p>

        <!-- IMAGENES -->
        <div class="grid md:grid-cols-3 gap-6 mt-10">

          <div class="bg-white p-4 rounded-xl shadow-lg">
            <Image
              src={imagen1}
              alt="Enunciado parte 1"
              class="w-full rounded-lg object-contain"
            />
          </div>

          <div class="bg-white p-4 rounded-xl shadow-lg">
            <Image
              src={imagen2}
              alt="Enunciado parte 2"
              class="w-full rounded-lg object-contain"
            />
          </div>

          <div class="bg-white p-4 rounded-xl shadow-lg">
            <Image
              src={imagen3}
              alt="Enunciado parte 3"
              class="w-full rounded-lg object-contain"
            />
          </div>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={employees}
            alt="Modelo ER Employees"
            class="w-full object-contain rounded-lg"
          />
        </div>

      </div>
    </div>

    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-yellow-500 via-amber-500 to-orange-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-yellow-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 5 — Empresa de Transportes
          </h2>
        </div>

        <div class="space-y-5 text-zinc-300 leading-relaxed">

          <p>
            Sistema para gestionar el reparto de paquetes
            en una empresa de transportes en Colombia.
          </p>

          <ul class="list-disc pl-6 space-y-3">

            <li>
              Los conductores poseen:
              cédula, nombre, teléfono,
              dirección, salario y ciudad.
            </li>

            <li>
              Los paquetes poseen:
              código, descripción,
              destinatario y dirección.
            </li>

            <li>
              Un conductor distribuye muchos paquetes.
            </li>

            <li>
              Cada paquete llega a una ciudad.
            </li>

            <li>
              Los camiones poseen:
              matrícula, modelo,
              tipo y potencia.
            </li>

            <li>
              Un conductor puede manejar
              distintos camiones.
            </li>

          </ul>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={transportes}
            alt="Modelo ER Transportes"
            class="w-full object-contain rounded-lg"
          />
        </div>

      </div>
    </div>

    <!-- MODELO 6 -->
    <div class="p-[2px] rounded-3xl bg-gradient-to-r from-fuchsia-500 via-pink-500 to-rose-500 mb-20 shadow-2xl">

      <div class="bg-zinc-900 p-10 rounded-3xl">

        <div class="mb-8">
          <span class="text-sm uppercase tracking-widest text-fuchsia-400">
            Base de Datos
          </span>

          <h2 class="text-3xl font-bold mt-2 text-white">
            Modelo 6 — Bienes Raíces
          </h2>
        </div>

        <div class="space-y-5 text-zinc-300 leading-relaxed">

          <p>
            Sistema de gestión de casas en venta
            y clientes interesados.
          </p>

          <ul class="list-disc pl-6 space-y-3">

            <li>
              Los agentes poseen:
              nombre completo, cédula,
              género, fecha de nacimiento
              y código único.
            </li>

            <li>
              Cada casa posee:
              precio, dirección,
              propietario y características.
            </li>

            <li>
              Las casas pueden tener:
              dormitorios, baños,
              calefacción y garaje.
            </li>

            <li>
              Los clientes especifican
              preferencias y rangos de precios.
            </li>

            <li>
              Una casa puede estar listada
              con distintas firmas.
            </li>

          </ul>

        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg mt-10">
          <Image
            src={employees}
            alt="Modelo ER Bienes Raíces"
            class="w-full object-contain rounded-lg"
          />
        </div>

      </div>
    </div>

  </section>

</DefaultLayout>