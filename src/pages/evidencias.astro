---
import DefaultLayout from '../layouts/DefaultLayout.astro'
---

<DefaultLayout
  title="Evidencias"
  description="Evidencias del curso Bases de Datos 1"
>
  <section class="container my-16">
    <h1 class="text-3xl font-bold mb-8">Evidencias</h1>

    <div class="space-y-6">


      <a 
        href={`${import.meta.env.BASE_URL}modelado/`}
        class="block p-6 border rounded-xl shadow-sm 
               hover:shadow-lg hover:scale-[1.02] 
               transition duration-300 cursor-pointer"
      >
        <h2 class="text-xl font-semibold mb-2">📘 Modelado</h2>
        <p>Ver todos los trabajos y evidencias de modelado de bases de datos.</p>
      </a>

      <!-- NORMALIZACIÓN -->
      <a 
        href={`${import.meta.env.BASE_URL}normalizacion/`}
        class="block p-6 border rounded-xl shadow-sm 
               hover:shadow-lg hover:scale-[1.02] 
               transition duration-300 cursor-pointer"
      >
        h2 class="text-xl font-semibold mb-2">🧩 Normalización</h2>
        <p>Ver todos los trabajos y evidencias de normalización de bases de datos.</p>
      </a>
      <!-- SQL -->
      <div class="p-6 border rounded-xl shadow-sm">
        <h2 class="text-xl font-semibold mb-2">💻 SQL</h2>
        <p>Consultas y prácticas desarrolladas en clase.</p>
      </div>

      <!-- PROYECTO -->
      <div class="p-6 border rounded-xl shadow-sm">
        <h2 class="text-xl font-semibold mb-2">🚀 Proyecto</h2>
        <p>Documentación y avances del proyecto final.</p>
      </div>

    </div>
  </section>
</DefaultLayout>