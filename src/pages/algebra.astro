---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Image } from 'astro:assets'
import aerolinea from '@assets/img/aerolinea.drawio.png'
import residuos from '@assets/img/Residuos.png'
import comidas from '@assets/img/comidas.png'
import imagen1 from '@assets/img/enunciado1.png'
import imagen2 from '@assets/img/enunciado2.png'
import imagen3 from '@assets/img/enunciado3.png'
import p from '@assets/img/p.png'
import h from '@assets/img/h.png'
import employees from '@assets/img/employe.png'
import transportes from '@assets/img/conductor.png'
import casa from '@assets/img/casa.png'
import total from '@assets/img/total.png'
import mer from '@assets/img/mer.png'
import mere from '@assets/img/mere.png'
---
<DefaultLayout title="Normalización - Einny Camyla">
<section class="py-20 container max-w-5xl mx-auto">

  <div class="text-center mb-16">
    <h1 class="text-5xl font-bold mb-4 text-white"> ALGEBRA </h1>
    <p class="text-zinc-400 text-lg"> Nejercicios en clase Y TALLER </p>
  </div>

  <div class="p-[2px] rounded-3xl bg-gradient-to-r from-violet-600 via-purple-500 to-fuchsia-500 mb-20 shadow-2xl">
    <div class="bg-zinc-900 p-10 rounded-3xl">
<div class="p-[2px] rounded-3xl bg-gradient-to-r from-emerald-600 via-teal-500 to-cyan-500 mb-20 shadow-2xl">
  <div class="bg-zinc-900 p-10 rounded-3xl">

    <div class="mb-10">
      <span class="text-sm uppercase tracking-widest text-emerald-400">Taller Evaluativo · Universidad El Bosque</span>
      <h2 class="text-3xl font-bold mt-2 text-white">Taller de Álgebra Relacional</h2>
      <p class="text-zinc-400 mt-2 text-sm">
        Por: Einny Camyla Poveda García y Sebastián Pérez Herrera · Docente: Ing. Christian Felipe Duarte Arévalo · Bases de Datos 1
      </p>
    </div>

    <div class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="px-3 py-1 rounded-full bg-emerald-500/20 text-emerald-300 text-xs font-semibold uppercase tracking-wider">Relaciones base</span>
        <h3 class="text-lg font-semibold text-white">Esquema relacional dado</h3>
      </div>
      <div class="bg-zinc-800/60 rounded-xl border border-zinc-700 p-5 font-mono text-xs text-zinc-300 space-y-2">
        <p><span class="text-yellow-400">empleado</span>(<span class="text-yellow-300">cod_emp</span>, nombre_empleado, calle, ciudad)</p>
        <p><span class="text-yellow-400">trabaja</span>(<span class="text-yellow-300">cod_emp</span>, <span class="text-yellow-300">cod_uni</span>, sueldo_mensual)</p>
        <p><span class="text-yellow-400">Universidad</span>(<span class="text-yellow-300">cod_uni</span>, nombre_uni, ciudad_uni)</p>
        <p><span class="text-yellow-400">jefe</span>(<span class="text-yellow-300">cod_jefe</span>, nombre_jefe, calle, ciudad)</p>
      </div>
    </div>

    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 1</span>
        <h3 class="text-base font-semibold text-white">Empleados que trabajan para la Universidad Central</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar los <strong class="text-white">nombres</strong> de todos los empleados que trabajan para la Universidad Central.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado</span> (empleado ⋈ trabaja ⋈ ρ<sub class="text-zinc-400">uni(ciudad_uni)</sub> (σ <span class="text-amber-300">nombre_uni = 'Universidad Central'</span> (Universidad)))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Se filtra Universidad por nombre, se renombra la columna de ciudad para evitar ambigüedad al hacer join, se encadenan los tres join naturales y finalmente se proyecta solo el nombre del empleado.
      </div>
    </div>

    <!-- EJ 2 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 2</span>
        <h3 class="text-base font-semibold text-white">Empleados de la Universidad de Los Andes con ciudad de residencia</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el <strong class="text-white">nombre y ciudad de residencia</strong> de todos los empleados que trabajan para la Universidad de Los Andes.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado, ciudad</span> (empleado ⋈ trabaja ⋈ ρ<sub class="text-zinc-400">uni(ciudad_uni)</sub> (σ <span class="text-amber-300">nombre_uni = 'Universidad de Los Andes'</span> (Universidad)))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Misma estructura que el ejercicio 1, cambiando el filtro de selección y proyectando adicionalmente la <span class="font-mono text-xs bg-zinc-800 px-1 rounded">ciudad</span> del empleado.
      </div>
    </div>

    <!-- EJ 3 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 3</span>
        <h3 class="text-base font-semibold text-white">Empleados de la U. Central que ganan más de $25.000.000 anuales</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el <strong class="text-white">nombre, calle y ciudad</strong> de empleados de la Universidad Central con salario anual mayor a $25.000.000.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado, calle, ciudad</span> (empleado ⋈ (σ <span class="text-amber-300">sueldo_mensual * 12 > 25000000</span> (trabaja ⋈ (ρ<sub class="text-zinc-400">uni(ciudad_uni)</sub> σ <span class="text-amber-300">nombre_uni = 'Universidad Central'</span> (Universidad)))))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        La condición de sueldo anual se aplica con <span class="font-mono text-xs bg-zinc-800 px-1 rounded">sueldo_mensual * 12 &gt; 25000000</span> sobre la relación <em>trabaja</em> ya unida con Universidad filtrada. Luego se hace join con empleado y se proyectan los tres atributos requeridos.
      </div>
    </div>

    <!-- EJ 4 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 4</span>
        <h3 class="text-base font-semibold text-white">Empleados que viven en la misma ciudad que su universidad</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el nombre de todos los empleados que viven en la <strong class="text-white">misma ciudad</strong> que la universidad para la que trabajan.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado</span> (σ <span class="text-amber-300">ciudad = ciudad_uni</span> (empleado ⋈ (trabaja ⋈ (ρ<sub class="text-zinc-400">uni(ciudad_uni)</sub>(Universidad)))))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Se renombra la ciudad de Universidad como <span class="font-mono text-xs bg-zinc-800 px-1 rounded">ciudad_uni</span> para distinguirla de la ciudad del empleado. Tras el join se seleccionan las filas donde ambas ciudades coincidan.
      </div>
    </div>

    <!-- EJ 5 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 5</span>
        <h3 class="text-base font-semibold text-white">Empleados que viven en la misma ciudad y calle que su jefe</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el nombre de todos los empleados que viven en la <strong class="text-white">misma ciudad y misma calle</strong> que sus jefes.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado</span> (σ <span class="text-amber-300">ciudad = ciudad_jefe ∧ calle = calle_jefe</span> (empleado × (ρ<sub class="text-zinc-400">J(cod_jefe, nombre_jefe, calle_jefe, ciudad_jefe)</sub>(jefe))))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Se usa <strong class="text-white">producto cartesiano (×)</strong> entre empleado y jefe (renombrado para evitar colisión de atributos). Luego la selección filtra los pares donde coincidan ciudad y calle simultáneamente. No se usa join natural porque no hay clave común directa entre ambas tablas.
      </div>
    </div>

    <!-- EJ 6 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 6</span>
        <h3 class="text-base font-semibold text-white">Empleados que NO trabajan para la Universidad Central</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el nombre de todos los empleados que <strong class="text-white">no trabajan</strong> para la Universidad Central.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_empleado</span> (empleado) <span class="text-red-400">−</span> π <span class="text-white">nombre_empleado</span> (empleado ⋈ trabaja ⋈ (σ <span class="text-amber-300">nombre_uni = 'Universidad Central'</span> (Universidad)))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Se usa la operación de <strong class="text-white">diferencia (−)</strong>: al conjunto de todos los empleados se le resta el subconjunto de los que sí trabajan en la Universidad Central. El resultado son quienes no tienen relación con ella.
      </div>
    </div>

    <!-- EJ 7 -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 7</span>
        <h3 class="text-base font-semibold text-white">Empleados que ganan más que cualquier empleado de Los Andes</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Averiguar el nombre de todos los empleados que ganan <strong class="text-white">más que cualquier empleado</strong> de la Universidad de Los Andes.</p>

      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed mb-2">
        MIN (sueldo_mensual)(empleado)
      </div>
    </div>

    <!-- EJ 8 -->
    <div class="mb-4">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full bg-teal-500/20 text-teal-300 text-xs font-semibold uppercase tracking-wider">Ejercicio 8</span>
        <h3 class="text-base font-semibold text-white">Universidades en cada ciudad donde está la Universidad Nacional</h3>
      </div>
      <p class="text-zinc-400 text-sm mb-3">Como la Universidad Nacional de Colombia está en varias ciudades, hallar todas las universidades instaladas en <strong class="text-white">cada ciudad</strong> donde también está la Nacional.</p>
      <div class="bg-zinc-800/50 border border-zinc-700 rounded-xl p-4 font-mono text-xs text-emerald-300 leading-relaxed">
        π <span class="text-white">nombre_uni, ciudad_uni</span> (Universidad) <span class="text-cyan-400">÷</span> π <span class="text-white">ciudad_uni</span> (σ <span class="text-amber-300">nombre_uni = 'Universidad Nacional de Colombia'</span> (Universidad))
      </div>
      <div class="mt-3 bg-zinc-800/30 rounded-lg p-3 text-xs text-zinc-400 border border-zinc-800">
        <span class="text-zinc-300 font-semibold">Explicación: </span>
        Se usa la operación de <strong class="text-white">división (÷)</strong>. El dividendo son todos los pares (nombre_uni, ciudad_uni); el divisor son las ciudades de la Nacional. El resultado son las universidades que aparecen en <em>todas</em> esas ciudades simultáneamente.
      </div>

    </div>

  </div>
</div>
        </div>
      </div> 

    </div> 
  </div> 

</section>
</DefaultLayout>